{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Virtual Voice",
  "identifier": "com.virtualvoice.app",
  "version": "1.5.0",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Virtual Voice",
        "width": 1000,
        "height": 700,
        "minWidth": 400,
        "minHeight": 100,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self' blob: data:; connect-src 'self' data: http://ipc.localhost ipc: tauri://localhost; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "resources/drivers/vbcable/*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installMode": "perMachine"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
